---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout
  title="Página no encontrada | Coaching de Raíz"
  description="La página que buscás no existe. Volvé al inicio de Coaching de Raíz."
  canonical="/404"
>
  <main class="min-h-screen flex flex-col items-center justify-center text-center px-4">
    <h1 class="text-6xl font-bold text-green-700 mb-4">404</h1>
    <p class="text-xl mb-8">Esta página no existe.</p>
    <a href="/" class="bg-green-600 text-white px-6 py-3 rounded-full hover:bg-green-700 transition">
      Volver al inicio
    </a>
  </main>
</BaseLayout>
