---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
import Navbar from '../components/Navbar.jsx';
import Hero from '../components/Hero.jsx';
import Services from '../components/Services.jsx';
import WhatIsCoaching from '../components/WhatIsCoaching.jsx';
import About from '../components/About.jsx';
import Contact from '../components/Contact.jsx';
import Footer from '../components/Footer.jsx';
import WhatsAppFloat from '../components/WhatsAppFloat.jsx';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Coaching de Raíz",
  "url": "https://www.coachingderaiz.com",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://www.coachingderaiz.com/?s={search_term_string}",
    "query-input": "required name=search_term_string"
  }
};
---

<BaseLayout
  title="Coaching de Raíz | Lucía Vallejo - Coach Ontológica Empresarial Buenos Aires"
  description="Coaching ontológico ejecutivo y de equipos en Buenos Aires. Lucía Vallejo, Coach Ontológica certificada, acompaña a líderes y organizaciones a transformar su forma de ser, liderar y vincularse. Sesión gratuita disponible."
  canonical="/"
  keywords="coaching ontológico Buenos Aires, coach ejecutiva Argentina, coaching de equipos, transformación organizacional, Lucía Vallejo coach, sesión gratuita coaching"
  schema={schema}
>
  <Navbar client:load />
  <main>
    <Hero client:load />
    <Services client:visible />
    <WhatIsCoaching client:visible />
    <About client:visible />
    <Contact client:visible />
  </main>
  <Footer client:load />
  <WhatsAppFloat client:load />
</BaseLayout>
