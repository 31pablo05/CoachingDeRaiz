---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
import Navbar from '../components/Navbar.jsx';
import WhatIsCoaching from '../components/WhatIsCoaching.jsx';
import Footer from '../components/Footer.jsx';
import WhatsAppFloat from '../components/WhatsAppFloat.jsx';

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Qué es el coaching ontológico?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El coaching ontológico es una disciplina que trabaja sobre el ser de las personas para transformar su forma de observar, interpretar y actuar en el mundo, generando resultados extraordinarios en su vida personal y profesional."
      }
    },
    {
      "@type": "Question",
      "name": "¿Para qué sirve el coaching ejecutivo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El coaching ejecutivo acompaña a líderes, directivos y gerentes a potenciar su liderazgo, mejorar su comunicación, gestionar equipos con mayor efectividad y alcanzar resultados que antes parecían imposibles."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuánto dura un proceso de coaching?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Un proceso de coaching ontológico típicamente dura entre 3 y 6 meses, con sesiones quincenales o mensuales, dependiendo de los objetivos y necesidades de cada persona u organización."
      }
    }
  ]
};
---

<BaseLayout
  title="¿Qué es el Coaching Ontológico? | Coaching Ejecutivo y de Equipos - Coaching de Raíz"
  description="Descubrí qué es el coaching ontológico, cómo funciona el coaching ejecutivo y por qué el coaching de equipos transforma organizaciones. Todo lo que necesitás saber antes de tu primera sesión gratuita."
  canonical="/que-es-coaching/"
  keywords="qué es coaching ontológico, qué es coaching ejecutivo, beneficios del coaching, coaching de equipos qué es, diferencia coaching y terapia"
  schema={schema}
>
  <Navbar client:load />
  <main>
    <WhatIsCoaching client:load />
  </main>
  <Footer client:load />
  <WhatsAppFloat client:load />
</BaseLayout>
